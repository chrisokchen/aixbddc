 # Server-side (read by next dev / next start, not exposed to browser)
  NODE_ENV=development
  API_BASE_URL=http://localhost:4000
  # API_TOKEN=...                       # optional bearer token; uncomment when backend requires it

  # Client-side (exposed to browser; must be prefixed NEXT_PUBLIC_)
  NEXT_PUBLIC_API_BASE_URL=http://localhost:4000