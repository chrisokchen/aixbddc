FROM python:3.11-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY requirements.txt .
RUN pip install --upgrade pip \
    && pip install -r requirements.txt

COPY pyproject.toml behave.ini alembic.ini ./
COPY ${PY_APP_DIR}/ ./${PY_APP_DIR}/
COPY tests/ ./tests/
COPY alembic/ ./alembic/

EXPOSE 8000

CMD ["uvicorn", "${PY_APP_MODULE}.main:app", "--host", "0.0.0.0", "--port", "8000"]
