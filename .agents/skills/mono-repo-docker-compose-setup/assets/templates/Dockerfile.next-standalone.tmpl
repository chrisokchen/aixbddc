# syntax=docker/dockerfile:1.7
# Generated by /mono-repo-docker-compose-setup
# Variables: {{node_version}} (default 20), {{frontend_port}} (default 3001),
#            {{has_messages_dir}} (true|false), {{has_public_dir}} (true|false),
#            {{api_base_path}} (default /api)

# ── Stage 1 — install deps ─────────────────────────────────────────
FROM node:{{node_version}}-alpine AS deps
WORKDIR /app
RUN apk add --no-cache libc6-compat

COPY package.json package-lock.json* ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

# ── Stage 2 — build ────────────────────────────────────────────────
FROM node:{{node_version}}-alpine AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

ENV NEXT_TELEMETRY_DISABLED=1 \
    NEXT_PUBLIC_MOCK_API=false \
    NEXT_PUBLIC_API_BASE_URL={{api_base_path}}

# Next standalone runtime expects these dirs even if empty.
RUN mkdir -p public

RUN npm run build

# ── Stage 3 — runtime ──────────────────────────────────────────────
FROM node:{{node_version}}-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT={{frontend_port}} \
    HOSTNAME=0.0.0.0

RUN addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 nextjs

COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/public ./public
{{#if has_messages_dir}}
# next-intl needs the messages JSON at runtime
COPY --from=builder --chown=nextjs:nodejs /app/messages ./messages
{{/if}}

USER nextjs
EXPOSE {{frontend_port}}

HEALTHCHECK --interval=15s --timeout=3s --start-period=20s --retries=5 \
  CMD wget --quiet --tries=1 --spider http://127.0.0.1:{{frontend_port}}/ || exit 1

CMD ["node", "server.js"]
