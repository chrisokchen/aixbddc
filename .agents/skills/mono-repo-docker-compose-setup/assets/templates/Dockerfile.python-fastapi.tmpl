# syntax=docker/dockerfile:1.7
# Generated by /mono-repo-docker-compose-setup
# Variables: {{python_version}} (default 3.11), {{has_alembic}} (true|false),
#            {{app_module}} (default app.main:app), {{backend_port}} (default 8000),
#            {{health_path}} (default /health)

FROM python:{{python_version}}-slim AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONPATH=/app

# psycopg[binary] doesn't need libpq-dev at runtime, but libpq5 is a safety net
# and curl is needed for the in-container healthcheck probe.
RUN apt-get update \
 && apt-get install -y --no-install-recommends curl libpq5 \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt ./
RUN pip install --upgrade pip && pip install -r requirements.txt

COPY pyproject.toml ./
{{#if has_alembic}}
COPY alembic.ini ./
COPY alembic ./alembic
{{/if}}
COPY app ./app

EXPOSE {{backend_port}}
HEALTHCHECK --interval=10s --timeout=3s --start-period=20s --retries=5 \
  CMD curl -fsS http://127.0.0.1:{{backend_port}}{{health_path}} || exit 1

{{#if has_alembic}}
CMD ["sh", "-c", "alembic upgrade head && uvicorn {{app_module}} --host 0.0.0.0 --port {{backend_port}}"]
{{else}}
CMD ["sh", "-c", "uvicorn {{app_module}} --host 0.0.0.0 --port {{backend_port}}"]
{{/if}}
