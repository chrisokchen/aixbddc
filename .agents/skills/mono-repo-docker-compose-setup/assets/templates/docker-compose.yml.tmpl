version: '3.8'

# Generated by /mono-repo-docker-compose-setup
# Variables resolved by RENDER (Phase 3 step 1.1):
#   {{backend_dir}}, {{frontend_dir}}, {{db_kind}},
#   {{backend_port}}, {{frontend_port}}, {{health_path}},
#   {{db_user}}, {{db_pass}}, {{db_name}},
#   {{publish_backend_host_port}} (true|false),
#   {{publish_frontend_host_port}} (true|false)

services:
  postgres:
    image: postgres:15
    container_name: aixbdd-postgres
    environment:
      POSTGRES_DB: {{db_name}}
      POSTGRES_USER: {{db_user}}
      POSTGRES_PASSWORD: {{db_pass}}
    expose:
      - "5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{db_user}}"]
      interval: 5s
      timeout: 5s
      retries: 10

  backend:
    build:
      context: ./{{backend_dir}}
      dockerfile: Dockerfile
    container_name: aixbdd-backend
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      DATABASE_URL: postgresql+psycopg://{{db_user}}:{{db_pass}}@postgres:5432/{{db_name}}
      PYTHONUNBUFFERED: "1"
{{#if publish_backend_host_port}}
    ports:
      - "{{backend_port}}:{{backend_port}}"
{{else}}
    # Host port {{backend_port}} not published — frontend reaches backend via docker network only.
    expose:
      - "{{backend_port}}"
{{/if}}
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://127.0.0.1:{{backend_port}}{{health_path}}"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 20s

  frontend:
    build:
      context: ./{{frontend_dir}}
      dockerfile: Dockerfile
    container_name: aixbdd-frontend
    depends_on:
      backend:
        condition: service_healthy
    environment:
      BACKEND_URL: http://backend:{{backend_port}}
      NEXT_PUBLIC_MOCK_API: "false"
      NEXT_PUBLIC_API_BASE_URL: /api
      PORT: "{{frontend_port}}"
      HOSTNAME: 0.0.0.0
{{#if publish_frontend_host_port}}
    ports:
      - "{{frontend_port}}:{{frontend_port}}"
{{else}}
    expose:
      - "{{frontend_port}}"
{{/if}}
    healthcheck:
      test: ["CMD-SHELL", "wget --quiet --tries=1 --spider http://127.0.0.1:{{frontend_port}}/ || exit 1"]
      interval: 15s
      timeout: 3s
      retries: 5
      start_period: 20s

volumes:
  postgres-data:
